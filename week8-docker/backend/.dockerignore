# .dockerignore — Backend
# Evita copiar ficheros innecesarios al contexto de build de Docker.
# Razones: [1] Build más rápido [2] Imagen más pequeña [3] Seguridad (no copiar secrets)

# ── Entornos virtuales Python ──────────────────────────────────────────────
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# ── Archivos de test ───────────────────────────────────────────────────────
tests/
test_*.py
*_test.py
pytest.ini
.pytest_cache/
.coverage
htmlcov/

# ── Archivos sensibles — NUNCA en la imagen ────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets/

# ── Git y CI ───────────────────────────────────────────────────────────────
.git/
.gitignore
.github/
.gitlab-ci.yml

# ── Documentación y herramientas de desarrollo ────────────────────────────
*.md
docs/
Makefile
.editorconfig
.pre-commit-config.yaml

# ── IDEs ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
