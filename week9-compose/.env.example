# ============================================================================
# .env.example — Template de variables de entorno
# Práctica 2 GSX | Semana 9
#
# INSTRUCCIONES:
#   1. Copia este fichero:  cp .env.example .env
#   2. Rellena los valores en .env con tus credenciales reales
#   3. NUNCA subas .env a Git — ya está en .gitignore
#
# Este fichero (.env.example) SÍ se sube a Git porque NO contiene valores reales.
# Sirve como documentación de qué variables son necesarias.
# ============================================================================

# ── Entorno de la aplicación ──────────────────────────────────────────────
# Valores posibles: development | staging | production
APP_ENV=production

# Versión semántica de la aplicación
APP_VERSION=1.0.0

# ── Base de datos PostgreSQL ──────────────────────────────────────────────
# Host: nombre del servicio Docker (resolución DNS interna)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=greendavcorp

# !! CAMBIAR en producción — usar contraseñas fuertes (mín. 32 caracteres)
# Generador: openssl rand -base64 32
DB_USER=greendavcorp_user
DB_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD_HERE

# ── CORS — Orígenes permitidos (separados por coma) ───────────────────────
# En producción: usar el dominio real de tu empresa
# Ejemplo: https://app.greendavcorp.com
ALLOWED_ORIGINS=http://localhost,http://localhost:80
